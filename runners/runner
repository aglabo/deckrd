set -euo pipefail

RUNNERS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ "${1:-}" == "list" ]]; then
  (cd "$RUNNERS_DIR" && find . -type f -executable \
    | sed 's|^\./||' \
    | grep -v '^runner$' \
    | sort)
  exit 0
fi

if [[ $# -lt 2 ]]; then
  echo "usage: runner <target> <action> [args...]" >&2
  exit 1
fi

target="$1"
action="$2"
shift 2

script="${RUNNERS_DIR}/${target}/${action}"

if [[ ! -x "$script" ]]; then
  echo "runner not found: ${target} ${action}" >&2
  exit 1
fi

exec "$script" "$@"
