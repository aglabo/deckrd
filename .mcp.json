{
  "mcpServers": {
    "codex-mcp": {
      "type:": "stdio",
      "command": "codex",
      "args": [
        "mcp-server"
      ]
    },
    "serena-mcp": {
      "type:": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project",
        "."
      ]
    }
  }
}
