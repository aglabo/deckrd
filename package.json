{
  "name": "@aglabo/deckrd",
  "version": "1.0.0",
  "description": "Development environment for project-starter-template",
  "private": true,
  "keywords": [
    "template",
    "starter",
    "oss",
    "development"
  ],
  "author": "atsushifx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aglabo/deckrd.git"
  },
  "scripts": {
    "prepare": "bash ./scripts/setup-dev-env.sh",
    "scan:secrets": "gitleaks dir --config ./configs/gitleaks.toml . && secretlint --secretlintrc ./configs/secretlint.config.yaml **/*",
    "format:dprint": "dprint fmt",
    "format:sh": "bash runners/ops/shell/format",
    "check:sh": "bash runners/ops/shell/format --list",
    "check:dprint": "dprint check",
    "lint:spells": "cspell  --config .vscode/cspell.json --cache --cache-location .cache/cspell/cSpellCache",
    "test:sh": "bash runners/ops/shell/test"
  }
}
