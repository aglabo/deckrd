{
  "name": "@aglabo/deckrd",
  "version": "1.0.0",
  "description": "Development environment for project-starter-template",
  "private": true,
  "keywords": [
    "template",
    "starter",
    "oss",
    "development"
  ],
  "author": "atsushifx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aglabo/deckrd.git"
  },
  "scripts": {
    "prepare": "bash ./scripts/setup-dev-env.sh",
    "release:changelog": "bash runners/run-git-cliff.sh changelog",
    "release:note": "bash runners/run-git-cliff.sh release-notes",
    "scan:secrets": "concurrently \"betterleaks protect --config C:/Users/atsushifx/workspaces/develop/ci-platform/configs/betterleaks.toml\" \"secretlint --secretlintrc ./configs/secretlint.config.yaml **/*\"",
    "check:sh": "bash runners/run-shfmt.sh --list .",
    "check:dprint": "dprint check",
    "format:dprint": "dprint fmt",
    "format:sh": "bash runners/run-shfmt.sh --format .",
    "lint:sh": "bash runners/run-shellcheck.sh ",
    "lint:spells": "cspell  --config .vscode/cspell.json --cache --cache-location .cache/cspell/cSpellCache",
    "lint:text": "bash runners/run-textlint.sh ",
    "lint:markdown": "bash runners/run-markdownlint.sh ",
    "test:sh": "bash runners/run-shellspec.sh ",
    "test:sh:all": "bash runners/run-shellspec.sh all"
  }
}
